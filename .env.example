BOT_TOKEN=123456:ABC-your-telegram-bot-token

# Comma-separated Telegram user IDs (only they can use the bot)
ADMIN_IDS=123456789

# SMTP (one account; add more later in DB if needed)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mail@example.com
SMTP_PASSWORD=secret
SMTP_FROM=mail@example.com
SMTP_USE_TLS=true

# Safety limits
SEND_DELAY_SEC=2
MAX_RECIPIENTS_PER_CAMPAIGN=5000

# ValidEmail.co — валидация имя@домен из JSON (2 ключа = 2x скорость)
VALIDEMAIL_API_KEY=
VALIDEMAIL_API_KEY_2=
# или через запятую: VALIDEMAIL_API_KEYS=key1,key2
VALIDEMAIL_URL=https://validemail.co/api/v1/validate
VALIDEMAIL_TIMEOUT=8
# Параллельных запросов на ОДИН ключ (2 ключа × 12 = до 24 одновременно)
VALIDEMAIL_CONCURRENCY=12
